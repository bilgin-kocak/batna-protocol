{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "./hardhat.config.ts",
    "./test/**/*.ts",
    "./tasks/**/*.ts",
    "./ignition/**/*.ts"
  ]
}
